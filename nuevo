let state={step:"landing",election:"",selectedIssues:[],rankedIssues:[],result:null,expandedIssue:null,followUp:"",followUpAnswer:null,followUpLoading:false,userOpinion:"",voiceFormat:"",voiceResult:null,voiceLoading:false,copied:false};

function setState(updates){
  Object.assign(state,updates);
  render();
}

function toggleIssue(id){
  let s=[...state.selectedIssues];
  if(s.includes(id))s=s.filter(i=>i!==id);
  else if(s.length<5)s.push(id);
  setState({selectedIssues:s});
}

function moveUp(i){
  if(!i)return;
  let a=[...state.rankedIssues];
  [a[i-1],a[i]]=[a[i],a[i-1]];
  setState({rankedIssues:a});
}

function moveDown(i){
  if(i>=state.rankedIssues.length-1)return;
  let a=[...state.rankedIssues];
  [a[i],a[i+1]]=[a[i+1],a[i]];
  setState({rankedIssues:a});
}

function analyze(){
  setState({result:DATA[state.election],step:"results"});
}

async function askFollowUp(){
  if(!state.followUp.trim())return;
  setState({followUpLoading:true,followUpAnswer:null});
  try{
    const r=await fetch("https://api.anthropic.com/v1/messages",{
      method:"POST",headers:{"Content-Type":"application/json"},
      body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1000,
        tools:[{type:"web_search_20250305",name:"web_search"}],
        messages:[{role:"user",content:`Context: researching "${state.result?.election_name}". Question: "${state.followUp}". Answer concisely, factually, unbiased. Search web if needed.`}]
      })
    });
    const data=await r.json();
    setState({followUpAnswer:data.content.filter(i=>i.type==="text").map(i=>i.text).join(""),followUpLoading:false});
  }catch(e){setState({followUpAnswer:"Sorry, something went wrong.",followUpLoading:false})}
}

async function generateVoice(){
  if(!state.userOpinion.trim()||!state.voiceFormat)return;
  setState({voiceLoading:true,voiceResult:null});
  const fmts={social:"a social media post (punchy, under 280 chars)",letter:"a formal letter to a political representative",argument:"talking points for a respectful dinner conversation",essay:"a short personal essay (3-4 paragraphs)"};
  try{
    const r=await fetch("https://api.anthropic.com/v1/messages",{
      method:"POST",headers:{"Content-Type":"application/json"},
      body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1500,
        messages:[{role:"user",content:`The user researched "${state.result?.election_name}" and formed this opinion:\n"${state.userOpinion}"\n\nHelp them express this as ${fmts[state.voiceFormat]}. Keep their authentic voice. Strengthen with facts. Make it compelling. Don't change their opinion. Output only the final text.`}]
      })
    });
    const data=await r.json();
    setState({voiceResult:data.content.filter(i=>i.type==="text").map(i=>i.text).join(""),voiceLoading:false});
  }catch(e){setState({voiceResult:"Sorry, something went wrong.",voiceLoading:false})}
}

function copyText(){
  navigator.clipboard.writeText(state.voiceResult);
  setState({copied:true});
  setTimeout(()=>setState({copied:false}),2000);
}

function reset(){
  setState({step:"landing",election:"",selectedIssues:[],rankedIssues:[],result:null,expandedIssue:null,followUp:"",followUpAnswer:null,userOpinion:"",voiceFormat:"",voiceResult:null});
}

function render(){
  const app=document.getElementById("app");
  
  if(state.step==="landing"){
    app.innerHTML=`
      <div style="text-align:center;max-width:600px;margin-bottom:48px">
        <div class="logo">✓</div>
        <h1 class="title">Informed Vote</h1>
        <p class="sub">Vote smart in 5 minutes. Get an unbiased, personalized comparison of candidates — then find your voice and make it heard.</p>
        <p class="tag">No bias. No fluff. Your voice, amplified.</p>
        <button class="btn" onclick="setState({step:'election'})">Get Started →</button>
      </div>
      <div class="cards">
        <div class="card"><span>🎯</span><h3>Personalized</h3><p>Prioritized by your issues</p></div>
        <div class="card"><span>⚖️</span><h3>Unbiased</h3><p>AI analysis, no agenda</p></div>
        <div class="card"><span>📢</span><h3>Find Your Voice</h3><p>Turn opinions into expression</p></div>
      </div>`;
    return;
  }

  if(state.step==="election"){
    app.innerHTML=`<div class="box">
      <div class="step-ind">Step 1 of 4</div>
      <h2 class="h2">What election are you voting in?</h2>
      <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:16px">
        ${ELECTIONS.map(e=>`<button class="opt ${state.election===e?'active':''}" onclick="setState({election:'${e}'})">${e}</button>`).join("")}
      </div>
      <div class="nav">
        <button class="btn2" onclick="setState({step:'landing'})">← Back</button>
        <button class="btn" ${!state.election?'disabled':''} onclick="setState({step:'issues'})">Next →</button>
      </div>
    </div>`;
    return;
  }

  if(state.step==="issues"){
    app.innerHTML=`<div class="box">
      <div class="step-ind">Step 2 of 4</div>
      <h2 class="h2">What issues matter most to you?</h2>
      <p style="font-size:15px;color:#64748b;margin:0 0 20px">Select 2-5 issues.</p>
      <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:12px">
        ${ISSUES.map(i=>`<button class="chip ${state.selectedIssues.includes(i.id)?'active':''}" onclick="toggleIssue('${i.id}')">${i.icon} ${i.label}</button>`).join("")}
      </div>
      <p style="font-size:13px;color:#64748b">${state.selectedIssues.length}/5 selected</p>
      <div class="nav">
        <button class="btn2" onclick="setState({step:'election'})">← Back</button>
        <button class="btn" ${state.selectedIssues.length<2?'disabled':''} onclick="setState({rankedIssues:ISSUES.filter(i=>state.selectedIssues.includes(i.id)),step:'rank'})">Rank My Issues →</button>
      </div>
    </div>`;
    return;
  }

  if(state.step==="rank"){
    app.innerHTML=`<div class="box">
      <div class="step-ind">Step 2 of 4 — Rank</div>
      <h2 class="h2">Rank by importance</h2>
      <p style="font-size:15px;color:#64748b;margin:0 0 20px">#1 = most important to you.</p>
      ${state.rankedIssues.map((issue,idx)=>`
        <div class="rank-item">
          <span class="rank-num">#${idx+1}</span>
          <span style="font-size:20px">${issue.icon}</span>
          <span style="flex:1;font-size:15px;color:#e2e8f0">${issue.label}</span>
          <button class="arr" onclick="moveUp(${idx})" ${idx===0?'disabled':''}>▲</button>
          <button class="arr" onclick="moveDown(${idx})" ${idx>=state.rankedIssues.length-1?'disabled':''}>▼</button>
        </div>`).join("")}
      <div class="nav">
        <button class="btn2" onclick="setState({rankedIssues:[],step:'issues'})">← Back</button>
        <button class="btn" onclick="analyze()">Analyze Candidates →</button>
      </div>
    </div>`;
    return;
  }

  if(state.step==="results"&&state.result){
    const r=state.result;
    app.innerHTML=`<div class="wide">
      <div style="text-align:center;margin-bottom:32px">
        <div class="step-ind">Step 3 of 4 — Results</div>
        <h2 class="title2">${r.election_name}</h2>
        <p style="font-size:15px;color:#94a3b8;line-height:1.6;max-width:600px;margin:0 auto">${r.election_context}</p>
      </div>
      <div class="sec">
        <h3 class="h3">🔑 Key Differences</h3>
        ${r.key_differences.map(d=>`<div class="diff-item"><span style="color:#7c3aed;margin-right:8px;font-weight:700">→</span>${d}</div>`).join("")}
      </div>
      <h3 class="h3">📊 Candidate Comparison</h3>
      <p style="font-size:14px;color:#64748b;margin:0 0 16px">Ordered by YOUR priorities. Click to expand.</p>
      ${state.rankedIssues.map(issue=>{
        const exp=state.expandedIssue===issue.id;
        return`<div class="issue-block">
          <button class="issue-head" onclick="setState({expandedIssue:state.expandedIssue==='${issue.id}'?null:'${issue.id}'})">
            <span>${issue.icon} ${issue.label}</span><span>${exp?'▼':'▶'}</span>
          </button>
          ${exp?`<div class="comp-grid">${r.candidates.map(c=>{
            const p=c.positions.find(p=>p.issue.toLowerCase().includes(issue.label.toLowerCase().split(" ")[0])||issue.label.toLowerCase().includes(p.issue.toLowerCase().split(" ")[0]));
            return`<div class="cand-card">
              <div class="cand-name">${c.name}<span class="badge">${c.party}</span></div>
              ${p?`
                <div style="margin-bottom:12px"><div class="lbl">Position</div><div style="font-size:14px;color:#cbd5e1;line-height:1.5">${p.stance}</div></div>
                <div style="margin-bottom:12px"><div class="lbl">Evidence</div><div style="font-size:13px;color:#94a3b8;line-height:1.5;font-style:italic">${p.evidence}</div></div>
                <div style="margin-bottom:12px"><div class="lbl">Impact on You</div><div style="font-size:13px;color:#86efac;line-height:1.5">${p.impact}</div></div>
                <div><div class="lbl">Source</div><div style="font-size:12px;color:#64748b">${p.source}</div></div>
              `:`<p style="font-size:14px;color:#475569;font-style:italic">No specific position found.</p>`}
            </div>`;
          }).join("")}</div>`:''}
        </div>`;
      }).join("")}
      <div class="sec" style="margin-top:24px">
        <h3 class="h3">📚 Sources</h3>
        <div>${r.sources.map(s=>`<a class="source-link" href="${s.url}" target="_blank">${s.name} ↗</a>`).join("")}</div>
      </div>
      <div class="sec">
        <h3 class="h3">💬 Have a question?</h3>
        <div style="display:flex;gap:8px">
          <input class="inp" style="flex:1" placeholder="e.g. What's their stance on student loans?" id="followUpInp" value="${state.followUp}" oninput="state.followUp=this.value" onkeydown="if(event.key==='Enter')askFollowUp()">
          <button class="btn" onclick="askFollowUp()" ${state.followUpLoading?'disabled':''}>${state.followUpLoading?'...':'Ask'}</button>
        </div>
        ${state.followUpAnswer?`<div style="margin-top:16px;font-size:14px;color:#cbd5e1;line-height:1.6;background:rgba(255,255,255,0.03);border-radius:12px;padding:16px">${state.followUpAnswer}</div>`:''}
      </div>
      <div style="text-align:center;margin-top:32px">
        <button class="btn" onclick="setState({step:'voice'})">Find Your Voice →</button>
      </div>
    </div>`;
    return;
  }

  if(state.step==="voice"){
    app.innerHTML=`<div class="wide">
      <div style="text-align:center;margin-bottom:32px">
        <div class="step-ind">Step 4 of 4 — Find Your Voice</div>
        <h2 class="title2">Make Your Voice Heard</h2>
        <p style="font-size:15px;color:#94a3b8;line-height:1.6;max-width:600px;margin:0 auto">Now that you're informed, express your opinion. Write what you think — messy, raw, any language — and we'll amplify it.</p>
      </div>
      <div class="sec">
        <h3 class="h3">✍️ What's your take?</h3>
        <textarea class="inp" placeholder="Write your honest opinion... messy, informal, even Spanglish." id="opinionInp" oninput="state.userOpinion=this.value">${state.userOpinion}</textarea>
      </div>
      <div class="sec">
        <h3 class="h3">📣 How do you want to express it?</h3>
        <div class="fmt-grid">
          ${FORMATS.map(f=>`<button class="opt ${state.voiceFormat===f.id?'active':''}" style="text-align:center" onclick="setState({voiceFormat:'${f.id}'})">
            <span style="font-size:24px">${f.icon}</span>
            <div style="font-size:14px;font-weight:600;color:#e2e8f0;margin-top:8px">${f.label}</div>
            <div style="font-size:12px;color:#64748b;margin-top:4px">${f.desc}</div>
          </button>`).join("")}
        </div>
      </div>
      ${!state.voiceResult?`<div style="text-align:center;margin-top:24px">
        <button class="btn" ${!state.userOpinion.trim()||!state.voiceFormat||state.voiceLoading?'disabled':''} onclick="generateVoice()">
          ${state.voiceLoading?'Crafting your voice...':'Amplify My Voice →'}
        </button>
      </div>`:''}
      ${state.voiceResult?`<div class="voice-result">
        <h3 class="h3">🎤 Your Voice, Amplified</h3>
        <div class="voice-text">${state.voiceResult}</div>
        <div style="display:flex;gap:12px;margin-top:16px;flex-wrap:wrap">
          <button class="btn-green" onclick="copyText()">${state.copied?'✓ Copied!':'📋 Copy to Clipboard'}</button>
          <button class="btn2" onclick="setState({voiceResult:null,voiceFormat:''})">Try Different Format</button>
        </div>
      </div>`:''}
      <div class="nav">
        <button class="btn2" onclick="setState({step:'results'})">← Back to Results</button>
        <button class="btn2" onclick="reset()">Start Over</button>
      </div>
      <div class="footer">
        <p>Built at CMU Anthropic Speedrun Hackathon 2026</p>
        <p>Powered by Claude AI · Data from Congress.gov, CBO, KFF, Ballotpedia, Reuters & official government records</p>
      </div>
    </div>`;
    return;
  }
}

render();
</script>
</body>
</html>
